{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Litmus Edge",
  "id": "litmus-edge-datasource",
  "metrics": true,
  "backend": true,
  "executable": "gpx_edge",
  "info": {
    "description": "The Litmus Edge data source plugin enables the visualization of real time data streaming from the edge in Grafana",
    "author": {
      "name": "Litmus Automation"
    },
    "keywords": ["datasource", "litmus edge", "edge", "real time", "streaming"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Documentation",
        "url": "https://github.com/litmusautomation/edge-datasource/blob/main/README.md"
      },
      {
        "name": "GitHub",
        "url": "https://github.com/litmusautomation/edge-datasource"
      },
      {
        "name": "Litmus",
        "url": "https://litmus.io"
      }
    ],
    "screenshots": [
      {
        "name": "Litmus Edge query editor and live panel",
        "path": "img/query-editor-screenshot.png"
      }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=12.2.0",
    "plugins": []
  }
}
