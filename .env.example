# Connection mode: true = connect to a remote Litmus Edge (required for local dev).
# The litmus-grafana image defaults to false and uses EDGE_DOCKER_GATEWAY_IP for inside-LE mode.
EDGE_EXTERNAL=true

# Inside-LE mode only — Docker gateway IP used to reach Litmus Edge from the container.
# Default: 10.30.50.1. Update it when your instance uses a different gateway IP.
EDGE_DOCKER_GATEWAY_IP=10.30.50.1

# External mode only — Litmus Edge address.
# Use `host` or `host:port`. Add `:port` only when Litmus Edge runs on a non-default port.
EDGE_HOSTNAME=your-litmus-edge-address

# Optional — NATS Proxy port for live data streaming (default: 4222)
EDGE_NATS_PROXY_PORT=4222

# External mode only — Access Account token for the remote LE instance
EDGE_ACCESS_ACCOUNT_TOKEN=your-access-account-token

# Optional — token for topic discovery (both modes)
EDGE_API_TOKEN=your-api-token
