# Connection mode: true = connect to a remote Litmus Edge (required for local dev).
# The litmus-grafana image defaults to false (auto-detect host from Docker bridge).
LITMUS_EDGE_EXTERNAL=true

# External mode only — hostname and Access Account token for the remote LE instance
LITMUS_EDGE_HOSTNAME=your-litmus-edge-hostname-or-ip
LITMUS_EDGE_ACCESS_ACCOUNT_TOKEN=your-access-account-token

# Optional — API token for topic autocomplete (both modes)
LITMUS_EDGE_API_TOKEN=your-api-token

# Plugin signing — same value as env.ROOT_URLS in .github/workflows/release.yml
ROOT_URLS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8080,http://localhost:8443

# Docker auth for pushing to the dev registry (us-docker.pkg.dev/litmus-customer-facing/litmus-solutions-dev)
# Used by: npm run docker:push-dev
DOCKER_AUTH_CONFIG_DEV='{"auths":{"us-docker.pkg.dev":{"auth":"<base64-encoded-service-account-key>"}}}'
